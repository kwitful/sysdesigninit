# --- Gemini (default) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-flash-latest
GOOGLE_GENAI_USE_ENTERPRISE=0
GOOGLE_API_KEY=

# --- OpenRouter (ADK LiteLlm path) ---
# Uncomment and fill to use OpenRouter instead of Gemini:
# LLM_PROVIDER=openrouter
# LLM_MODEL=openrouter/openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-v1-...
# OR_SITE_URL=https://github.com/your/repo
# OR_APP_NAME=sysdesigninit

# --- Generic LiteLLM (any LiteLLM provider string) ---
# LLM_PROVIDER=litellm
# LLM_MODEL=anthropic/claude-3-haiku-20240307
# ANTHROPIC_API_KEY=
